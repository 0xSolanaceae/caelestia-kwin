#!/bin/bash

RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}"

# Fast-path for polling commands
if [ "$1" = "clients" ] && [ "$2" = "-j" ]; then
    cat "$RUNTIME_DIR/qs_kwin_windows.json" 2>/dev/null || echo "[]"
    exit 0
fi
if [ "$1" = "monitors" ] && [ "$2" = "-j" ]; then
    cat "$RUNTIME_DIR/qs_kwin_monitors.json" 2>/dev/null || echo "[]"
    exit 0
fi
if [ "$1" = "workspaces" ] && [ "$2" = "-j" ]; then
    cat "$RUNTIME_DIR/qs_kwin_workspaces.json" 2>/dev/null || echo "[]"
    exit 0
fi
if [ "$1" = "activeworkspace" ] && [ "$2" = "-j" ]; then
    cat "$RUNTIME_DIR/qs_kwin_activeworkspace.json" 2>/dev/null || echo "{}"
    exit 0
fi
if [ "$1" = "layers" ] && [ "$2" = "-j" ]; then
    echo '{}'
    exit 0
fi

# Fallback to python bridge for complex commands (dispatch, globalshortcuts, etc.)
exec /usr/bin/env python3 "$HOME/.local/bin/hyprctl.py" "$@"

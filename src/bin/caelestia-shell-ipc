#!/usr/bin/env bash

set -euo pipefail

SHELL_CONFIG="$HOME/.config/quickshell/caelestia/shell.qml"

if [[ ! -f "$SHELL_CONFIG" ]]; then
    echo "Caelestia shell config not found: $SHELL_CONFIG" >&2
    exit 1
fi

if command -v quickshell >/dev/null 2>&1; then
    QUICKSHELL_PATH="$(command -v quickshell)"
elif command -v qs >/dev/null 2>&1; then
    QUICKSHELL_PATH="$(command -v qs)"
else
    echo "Quickshell is not installed or is not available in PATH." >&2
    exit 127
fi

# The KDE autostart entry launches the shell by path so it is independent of
# the installed caelestia-cli version. Select the same instance here and do
# not filter by display: keyd and KDE autostart can expose different display
# environment values even though they belong to the same graphical session.
exec "$QUICKSHELL_PATH" -p "$SHELL_CONFIG" ipc --any-display call "$@"
